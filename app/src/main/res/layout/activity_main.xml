<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FC"
    android:padding="0dp"
    tools:context=".MainActivity">

    <!-- Top toolbar-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light"
        app:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:titleTextColor="@android:color/white"
        app:title="">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/matt_logo_white"
                android:scaleType="fitCenter"
                android:contentDescription="Team Logo"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/navigation_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>
<!--        app:navigationIcon="@drawable/matt_logo_white"-->
<!--        app:navigationContentDescription="Team Logo"-->




<!--        app:logo="@drawable/matt_logo_white"-->
<!--        app:logoDescription="@string/toolbar_logo_desc"-->








    <!-- Content container: keeps the screen content padded while toolbar spans full width -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_choose_action"
            android:textSize="16sp"
            android:textColor="#555"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Menu Buttons Container -->
        <LinearLayout
            android:id="@+id/menu_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/subtitle_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Start Scan Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/scan_button"
                style="@style/MenuButton"
                android:text="@string/start_scan"
                android:contentDescription="@string/start_scan_cd"/>

            <!-- View Map Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_map_button"
                style="@style/MenuButton"
                android:text="@string/view_map"
                android:contentDescription="@string/view_map_cd"/>

            <!-- Record RSSI Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/record_rssi_button"
                style="@style/MenuButton"
                android:text="@string/record_signal"
                android:contentDescription="@string/record_signal_cd"/>

            <!-- Admin Panel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/calibration_button"
                style="@style/MenuButton"
                android:text="@string/admin_panel"
                android:contentDescription="@string/admin_panel_cd"/>

            <!-- Permissions Debug Button (previously referenced in code) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/permissions_debug_button"
                style="@style/MenuButton"
                android:text="@string/permissions_debug"
                android:contentDescription="@string/permissions_debug_cd"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Scan Results Header -->
        <TextView
            android:id="@+id/scan_results_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_results"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#222"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/menu_container"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/scan_results_recycler_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/scan_results_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/row_scan_result"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
